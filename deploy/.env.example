APP_VERSION=local
IMAGE_REPO_PREFIX=grtsinry43/
# Docker Hub mirror for nginx/postgres/redis (China)
# DOCKER_MIRROR=docker.1ms.run/
DOCKER_MIRROR=

NGINX_PORT=80

POSTGRES_DB=grtblog
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me

REDIS_PASSWORD=
REDIS_PREFIX=grtblog:

AUTH_SECRET=replace-with-a-strong-secret

APP_UPDATE_CHECK_ENABLED=true
APP_UPDATE_CHECK_REPO=grtsinry43/grtblog
APP_UPDATE_CHANNEL=stable

# Whole-site backup and restore limits (bytes)
BACKUP_COMMAND_TIMEOUT=30m
BACKUP_DOWNLOAD_TICKET_TTL=10m
BACKUP_RESTORE_MAX_ARCHIVE_BYTES=10737418240
BACKUP_RESTORE_MAX_EXTRACTED_BYTES=53687091200

# Admin panel (build-time, baked into JS bundle)
VITE_APP_BASE=/admin/
VITE_APP_NAME=Grtblog Admin
VITE_APP_TITLE=管理后台
VITE_WATERMARK_CONTENT=
VITE_API_BASE_URL=/api/v2
